{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@suika/shared": ["./packages/shared/src/index.ts"],
      "@suika/memory": ["./packages/memory/src/index.ts"],
      "@suika/knowledge": ["./packages/knowledge/src/index.ts"],
      "@suika/agents": ["./packages/agents/src/index.ts"],
      "@suika/workflows": ["./packages/workflows/src/index.ts"],
      "@suika/autonomy": ["./packages/autonomy/src/index.ts"],
      "@suika/companion": ["./packages/companion/src/index.ts"],
      "@suika/providers": ["./packages/providers/src/index.ts"],
      "@suika/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/**/*.ts",
    "services/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "out", "build"]
}
